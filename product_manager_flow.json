      {
        "width": 384,
        "height": 689,
        "id": "PythonFunction-AddProduct",
        "type": "PythonFunction",
        "data": {
          "type": "PythonFunction",
          "node": {
            "template": {
              "code": {
                "required": true,
                "placeholder": "",
                "show": true,
                "name": "code",
                "value": "import sqlite3\nimport json\nfrom langflow.custom import Component\nfrom langflow.schema import Data\n\nclass AddProductTool(Component):\n    display_name = \"Add Product\"\n    description = \"Prida novy produkt do databáze\"\n    \n    def build(self, name: str, price: float, stock: int, category: str) -> Data:\n        \"\"\"Prida novy produkt\"\"\"\n        try:\n            conn = sqlite3.connect('products.db')\n            cursor = conn.cursor()\n            \n            cursor.execute('''\n                INSERT INTO products (name, price, stock, category)\n                VALUES (?, ?, ?, ?)\n            ''', (name, price, stock, category))\n            \n            product_id = cursor.lastrowid\n            conn.commit()\n            conn.close()\n            \n            product = {\n                'id': product_id,\n                'name': name,\n                'price': price,\n                'stock': stock,\n                'category': category\n            }\n            \n            result_text = f\"Produkt pridan:\\n\\n\"\n            result_text += f\"ID: {product_id}\\n\"\n            result_text += f\"Nazev: {name}\\n\"\n            result_text += f\"Cena: {price} Kč\\n\"\n            result_text += f\"Sklad: {stock} ks\\n\"\n            result_text += f\"Kategorie: {category}\"\n            \n            return Data(\n                data={\"message\": \"Produkt pridan\", \"product\": product},\n                text=result_text\n            )\n            \n        except Exception as e:\n            return Data(\n                data={\"error\": str(e)},\n                text=f\"Chyba pri pridavani produktu: {str(e)}\"\n            )",
                "display_name": "Code",
                "advanced": false,
                "dynamic": true,
                "info": "",
                "type": "code",
                "multiline": true
              }
            },
            "description": "Python funkce pro pridaní produktu",
            "display_name": "Add Product Tool",
            "documentation": "",
            "base_classes": [
              "Tool"
            ],
            "name": "PythonFunction",
            "output_types": [
              "Tool"
            ]
          }
        },
