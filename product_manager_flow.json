      {
        "width": 384,
        "height": 689,
        "id": "PythonFunction-GetAll",
        "type": "PythonFunction",
        "data": {
          "type": "PythonFunction",
          "node": {
            "template": {
              "code": {
                "required": true,
                "placeholder": "",
                "show": true,
                "name": "code",
                "value": "import sqlite3\nimport json\nfrom langflow.custom import Component\nfrom langflow.schema import Data\n\nclass GetAllProductsTool(Component):\n    display_name = \"Get All Products\"\n    description = \"Zobrazi vsechny produkty v databazi\"\n    \n    def build(self) -> Data:\n        \"\"\"Vrati vsechny produkty\"\"\"\n        try:\n            conn = sqlite3.connect('products.db')\n            cursor = conn.cursor()\n            \n            cursor.execute('''\n                SELECT id, name, price, stock, category \n                FROM products \n                ORDER BY category, name\n            ''')\n            \n            results = cursor.fetchall()\n            conn.close()\n            \n            if not results:\n                return Data(\n                    data={\"message\": \"Databaze je prazdna\"},\n                    text=\"Databaze neobsahuje zadne produkty\"\n                )\n            \n            products = []\n            for row in results:\n                products.append({\n                    'id': row[0],\n                    'name': row[1],\n                    'price': row[2],\n                    'stock': row[3],\n                    'category': row[4]\n                })\n            \n            # Seskupeni podle kategorii\n            by_category = {}\n            for p in products:\n                cat = p['category']\n                if cat not in by_category:\n                    by_category[cat] = []\n                by_category[cat].append(p)\n            \n            result_text = f\"Celkem {len(products)} produktu:\\n\\n\"\n            \n            for category, items in sorted(by_category.items()):\n                result_text += f\"\\n═══ {category} ═══\\n\\n\"\n                for p in items:\n                    result_text += f\"  [{p['id']}] {p['name']}\\n\"\n                    result_text += f\"      {p['price']} Kč | {p['stock']} ks\\n\\n\"\n            \n            return Data(\n                data={\"products\": products, \"count\": len(products), \"categories\": list(by_category.keys())},\n                text=result_text\n            )\n            \n        except Exception as e:\n            return Data(\n                data={\"error\": str(e)},\n                text=f\"Chyba pri nacitani produktu: {str(e)}\"\n            )",
                "display_name": "Code",
                "advanced": false,
                "dynamic": true,
                "info": "",
                "type": "code",
                "multiline": true
              }
            },
            "description": "Python funkce pro zobrazeni vsech produktu",
            "display_name": "Get All Products Tool",
            "documentation": "",
            "base_classes": [
              "Tool"
            ],
            "name": "PythonFunction",
            "output_types": [
              "Tool"
            ]
          }
