      {
        "width": 384,
        "height": 689,
        "id": "PythonFunction-UpdateStock",
        "type": "PythonFunction",
        "data": {
          "type": "PythonFunction",
          "node": {
            "template": {
              "code": {
                "required": true,
                "placeholder": "",
                "show": true,
                "name": "code",
                "value": "import sqlite3\nimport json\nfrom langflow.custom import Component\nfrom langflow.schema import Data\n\nclass UpdateStockTool(Component):\n    display_name = \"Update Stock\"\n    description = \"Aktualizuje pocet kusu produktu na sklade\"\n    \n    def build(self, product_id: int, new_stock: int) -> Data:\n        \"\"\"Aktualizuje stav skladu\"\"\"\n        try:\n            conn = sqlite3.connect('products.db')\n            cursor = conn.cursor()\n            \n            # Zkontrolujeme, zda produkt existuje\n            cursor.execute('SELECT * FROM products WHERE id = ?', (product_id,))\n            product = cursor.fetchone()\n            \n            if not product:\n                conn.close()\n                return Data(\n                    data={\"error\": f\"Produkt s ID {product_id} neexistuje\"},\n                    text=f\"Produkt s ID {product_id} nebyl nalezen\"\n                )\n            \n            old_stock = product[3]\n            \n            # Aktualizace skladu\n            cursor.execute(\n                'UPDATE products SET stock = ? WHERE id = ?',\n                (new_stock, product_id)\n            )\n            conn.commit()\n            \n            # Nacteni aktualizovanych dat\n            cursor.execute('SELECT * FROM products WHERE id = ?', (product_id,))\n            updated = cursor.fetchone()\n            conn.close()\n            \n            result_text = f\"Sklad aktualizovan:\\n\\n\"\n            result_text += f\"Produkt: {updated[1]} (ID: {product_id})\\n\"\n            result_text += f\"Stary stav: {old_stock} ks\\n\"\n            result_text += f\"Novy stav: {new_stock} ks\\n\"\n            result_text += f\"Zmena: {new_stock - old_stock:+d} ks\"\n            \n            return Data(\n                data={\n                    \"message\": \"Sklad aktualizovan\",\n                    \"product_id\": product_id,\n                    \"old_stock\": old_stock,\n                    \"new_stock\": new_stock\n                },\n                text=result_text\n            )\n            \n        except Exception as e:\n            return Data(\n                data={\"error\": str(e)},\n                text=f\"Chyba pri aktualizaci skladu: {str(e)}\"\n            )",
                "display_name": "Code",
                "advanced": false,
                "dynamic": true,
                "info": "",
                "type": "code",
                "multiline": true
              }
            },
            "description": "Python funkce pro aktualizaci skladu",
            "display_name": "Update Stock Tool",
            "documentation": "",
            "base_classes": [
              "Tool"
            ],
            "name": "PythonFunction",
            "output_types": [
              "Tool"
            ]
          }
        },
