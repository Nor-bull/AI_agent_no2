      {
        "width": 384,
        "height": 689,
        "id": "PythonFunction-SearchProducts",
        "type": "PythonFunction",
        "data": {
          "type": "PythonFunction",
          "node": {
            "template": {
              "code": {
                "required": true,
                "placeholder": "",
                "show": true,
                "name": "code",
                "value": "import sqlite3\nimport json\nfrom langflow.custom import Component\nfrom langflow.schema import Data\n\nclass SearchProductsTool(Component):\n    display_name = \"Search Products\"\n    description = \"Vyhleda produkty v databazi podle nazvu nebo kategorie\"\n    \n    def build(self, query: str) -> Data:\n        \"\"\"Vyhleda produkty podle dotazu\"\"\"\n        try:\n            conn = sqlite3.connect('products.db')\n            cursor = conn.cursor()\n            \n            cursor.execute('''\n                SELECT id, name, price, stock, category \n                FROM products \n                WHERE name LIKE ? OR category LIKE ?\n                ORDER BY category, name\n            ''', (f'%{query}%', f'%{query}%'))\n            \n            results = cursor.fetchall()\n            conn.close()\n            \n            if not results:\n                return Data(\n                    data={\"message\": f\"Nenalezeny zadne produkty pro: {query}\"},\n                    text=f\"Nenalezeny zadne produkty pro: {query}\"\n                )\n            \n            products = []\n            for row in results:\n                products.append({\n                    'id': row[0],\n                    'name': row[1],\n                    'price': row[2],\n                    'stock': row[3],\n                    'category': row[4]\n                })\n            \n            result_text = f\"Nalezeno {len(products)} produktů:\\n\\n\"\n            for p in products:\n                result_text += f\"ID: {p['id']} | {p['name']}\\n\"\n                result_text += f\"  Cena: {p['price']} Kč | Sklad: {p['stock']} ks\\n\"\n                result_text += f\"  Kategorie: {p['category']}\\n\\n\"\n            \n            return Data(\n                data={\"products\": products, \"count\": len(products)},\n                text=result_text\n            )\n            \n        except Exception as e:\n            return Data(\n                data={\"error\": str(e)},\n                text=f\"Chyba pri vyhledavani: {str(e)}\"\n            )",
                "display_name": "Code",
                "advanced": false,
                "dynamic": true,
                "info": "",
                "type": "code",
                "multiline": true
              }
            },
            "description": "Python funkce pro vyhledavani produktu",
            "display_name": "Search Products Tool",
            "documentation": "",
            "base_classes": [
              "Tool"
            ],
            "name": "PythonFunction",
            "output_types": [
              "Tool"
            ]
          }
        },
